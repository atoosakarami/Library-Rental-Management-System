# ---------- Submission Handlers ----------
def submit_borrower():
    name = borrower_name.get().strip()
    addr = address.get().strip()
    phone_num = phone.get().strip()
    
    if not name or not addr or not phone_num:
        messagebox.showerror("Error", "All fields are required for borrower")
        return
    
    try:
        cursor.execute('''
            INSERT INTO BORROWER (Name, Address, Phone)
            VALUES (?, ?, ?)
        ''', (name, addr, phone_num))
        new_card_no = cursor.lastrowid
        db.commit()
        messagebox.showinfo("Success", f"Borrower '{name}' added successfully!\nNew Card Number: {new_card_no}")
    except sqlite3.Error as e:
        messagebox.showerror("Database Error", str(e))
    
    hide_all()

def submit_checkout():
    b_id = book_id.get().strip()
    c_id = borrower_id.get().strip()
    
    if not b_id or not c_id:
        messagebox.showerror("Error", "Book ID and Borrower ID are required")
        return
    
    try:
        ensure_default_branch()
        
        # Check if book exists
        cursor.execute('SELECT Book_Id FROM BOOK WHERE Book_Id = ?', (b_id,))
        if not cursor.fetchone():
            messagebox.showerror("Error", f"Book ID {b_id} does not exist")
            return
        
        # Check if borrower exists
        cursor.execute('SELECT Card_No FROM BORROWER WHERE Card_No = ?', (c_id,))
        if not cursor.fetchone():
            messagebox.showerror("Error", f"Borrower ID {c_id} does not exist")
            return
        
        cursor.execute('''
            INSERT INTO BOOK_LOANS
            (Book_Id, Branch_Id, Card_No, Date_Out, Due_Date, Returned_Date)
            VALUES (?, ?, ?, DATE('now'), DATE('now', '+7 days'), NULL)
        ''', (b_id, 1, c_id))
        db.commit()
        
        # Show updated copies
        cursor.execute('''
            SELECT Book_Id, Branch_Id, No_Of_Copies
            FROM BOOK_COPIES
            WHERE Book_Id = ?
        ''', (b_id,))
        rows = cursor.fetchall()
        
        if rows:
            show_results("Updated Book Copies", ["Book ID", "Branch ID", "Remaining Copies"], rows)
            messagebox.showinfo("Success", "Book checked out successfully!")
        else:
            messagebox.showinfo("Success", "Book checked out, but no copy record found.")
            
    except sqlite3.Error as e:
        messagebox.showerror("Checkout Error", str(e))
    
    hide_all()

def submit_book():
    title = book_title.get().strip()
    publisher = book_publisher.get().strip()
    author = book_author.get().strip()
    
    if not title or not publisher or not author:
        messagebox.showerror("Error", "Book title, publisher, and author are required")
        return
    
    try:
        ensure_five_branches()
        
        # Check if publisher exists
        cursor.execute('SELECT Publisher_Name FROM PUBLISHER WHERE Publisher_Name = ?', (publisher,))
        if not cursor.fetchone():
            # Insert the publisher if it doesn't exist
            cursor.execute('INSERT INTO PUBLISHER (Publisher_Name) VALUES (?)', (publisher,))
        
        # Insert book
        cursor.execute('''
            INSERT INTO BOOK (Title, Publisher_Name)
            VALUES (?, ?)
        ''', (title, publisher))
        new_book_id = cursor.lastrowid
        
        # Insert author
        cursor.execute('''
            INSERT INTO BOOK_AUTHORS (Book_Id, Author_Name)
            VALUES (?, ?)
        ''', (new_book_id, author))
        
        # Insert 5 copies to each branch
        copies_seed = [(new_book_id, branch_id, 5) for branch_id in range(1, 6)]
        cursor.executemany('''
            INSERT OR REPLACE INTO BOOK_COPIES (Book_Id, Branch_Id, No_Of_Copies)
            VALUES (?, ?, ?)
        ''', copies_seed)
        
        db.commit()
        messagebox.showinfo("Success", f"Book '{title}' added successfully!\nBook ID: {new_book_id}\n5 copies added to each of the 5 branches.")
        
    except sqlite3.Error as e:
        messagebox.showerror("Database Error", str(e))
    
    hide_all()

def submit_list_copies():
    b_id = copies_book_id.get().strip()
    
    if not b_id:
        messagebox.showerror("Error", "Book ID is required")
        return
    
    try:
        cursor.execute('''
            SELECT bc.Book_Id, b.Title, bc.Branch_Id, lb.Branch_Name, bc.No_Of_Copies
            FROM BOOK_COPIES bc
            JOIN BOOK b ON bc.Book_Id = b.Book_Id
            JOIN LIBRARY_BRANCH lb ON bc.Branch_Id = lb.Branch_Id
            WHERE bc.Book_Id = ?
            ORDER BY bc.Branch_Id
        ''', (b_id,))
        rows = cursor.fetchall()
        
        if rows:
            show_results("Book Copies", ["Book ID", "Title", "Branch ID", "Branch Name", "Number of Copies"], rows)
        else:
            messagebox.showinfo("No Data", f"No copy records found for Book ID {b_id}")
            
    except sqlite3.Error as e:
        messagebox.showerror("Database Error", str(e))
    
    hide_all()

