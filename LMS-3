# ---------- Requirement 4: Copies Loaned Out by Book Title ----------
def submit_copies_loaned():
    title = loaned_title_entry.get().strip()
    
    if not title:
        messagebox.showerror("Error", "Please enter a book title")
        return
    
    try:
        # First check if the book exists
        cursor.execute('SELECT Book_Id, Title FROM BOOK WHERE Title = ?', (title,))
        book = cursor.fetchone()
        
        if not book:
            messagebox.showinfo("Book Not Found", f"No book found with title '{title}'")
            hide_all()
            return
        
        book_id = book[0]
        
        # Query to get copies loaned out per branch (including returned and not returned)
        query = '''
            SELECT 
                lb.Branch_Name,
                COUNT(bl.Book_Id) AS Total_Copies_Loaned,
                SUM(CASE WHEN bl.Returned_Date IS NULL THEN 1 ELSE 0 END) AS Currently_Checked_Out,
                SUM(CASE WHEN bl.Returned_Date IS NOT NULL THEN 1 ELSE 0 END) AS Returned_Copies
            FROM BOOK_LOANS bl
            JOIN LIBRARY_BRANCH lb ON bl.Branch_Id = lb.Branch_Id
            WHERE bl.Book_Id = ?
            GROUP BY lb.Branch_Name, lb.Branch_Id
            ORDER BY lb.Branch_Id
        '''
        
        cursor.execute(query, (book_id,))
        rows = cursor.fetchall()
        
        if rows:
            # Format the results nicely
            formatted_rows = []
            for row in rows:
                branch_name, total, currently_out, returned = row
                formatted_rows.append((branch_name, total, currently_out, returned))
            
            show_results(
                f"Loan Statistics for '{title}'", 
                ["Branch Name", "Total Loans (All Time)", "Currently Checked Out", "Returned Copies"], 
                formatted_rows
            )
        else:
            messagebox.showinfo("No Loans", f"The book '{title}' exists but has never been loaned out.")
            
    except sqlite3.Error as e:
        messagebox.showerror("Database Error", str(e))
    
    hide_all()

# ---------- Requirement 6a: Borrower Late Fee Balance ----------
def submit_borrower_balance():
    borrower_id_val = balance_borrower_id_entry.get().strip()
    name_part = balance_name_entry.get().strip()
    
    # Build dynamic query using the view vBookLoanInfo
    query = '''
        SELECT 
            Card_No, 
            Borrower_Name, 
            COALESCE(SUM(LateFeeBalance), 0) AS TotalLateFeeBalance
        FROM vBookLoanInfo
        WHERE 1=1
    '''
    params = []
    
    if borrower_id_val:
        query += " AND Card_No = ?"
        params.append(borrower_id_val)
    
    if name_part:
        query += " AND Borrower_Name LIKE ?"
        params.append(f"%{name_part}%")
    
    query += " GROUP BY Card_No, Borrower_Name"
    
    if not borrower_id_val and not name_part:
        query += " ORDER BY TotalLateFeeBalance DESC"
    
    try:
        cursor.execute(query, params)
        rows = cursor.fetchall()
        
        if rows:
            # Format balance as USD
            formatted_rows = []
            for row in rows:
                card, name, bal = row
                formatted_rows.append((card, name, f"${bal:.2f}" if bal is not None else "$0.00"))
            show_results("Borrower Late Fee Balance", ["Card Number", "Borrower Name", "Total Balance"], formatted_rows)
        else:
