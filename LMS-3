# ---------- Submission Handlers ----------
def submit_borrower():
    name = borrower_name.get().strip()
    addr = address.get().strip()
    phone_num = phone.get().strip()
    if not name or not addr or not phone_num:
        messagebox.showerror("Error", "All fields required for borrower")
        return
    try:
        cursor.execute('INSERT INTO BORROWER (Name, Address, Phone) VALUES (?, ?, ?)', (name, addr, phone_num))
        new_card_no = cursor.lastrowid
        db.commit()
        messagebox.showinfo("Success", f"Borrower '{name}' added.\nCard Number: {new_card_no}")
    except sqlite3.Error as e:
        messagebox.showerror("DB Error", str(e))
    hide_all()

def submit_checkout():
    b_id = book_id.get().strip()
    c_id = borrower_id.get().strip()
    if not b_id or not c_id:
        messagebox.showerror("Error", "Book ID and Borrower ID required")
        return
    try:
        ensure_default_branch()
        cursor.execute('''
            INSERT INTO BOOK_LOANS (Book_Id, Branch_Id, Card_No, Date_Out, Due_Date, Returned_Date)
            VALUES (?, ?, ?, DATE('now'), DATE('now', '+7 days'), NULL)
        ''', (b_id, 1, c_id))
        db.commit()
        cursor.execute('SELECT Book_Id, Branch_Id, No_Of_Copies FROM BOOK_COPIES WHERE Book_Id = ?', (b_id,))
        rows = cursor.fetchall()
        if rows:
            show_results("Updated Book Copies", ["Book_Id", "Branch_Id", "No_Of_Copies"], rows)
        else:
            messagebox.showinfo("Checkout", "Book checked out, but no copy record found.")
    except sqlite3.Error as e:
        messagebox.showerror("Checkout Error", str(e))
    hide_all()

def submit_book():
    title = book_title.get().strip()
    publisher = book_publisher.get().strip()
    author = book_author.get().strip()
    if not title or not publisher or not author:
        messagebox.showerror("Error", "Title, Publisher, Author required")
        return
    try:
        ensure_five_branches()
        cursor.execute('SELECT 1 FROM PUBLISHER WHERE Publisher_Name = ?', (publisher,))
        if not cursor.fetchone():
            messagebox.showerror("Error", f"Publisher '{publisher}' does not exist. Use existing publisher.")
            return
        cursor.execute('INSERT INTO BOOK (Title, Publisher_Name) VALUES (?, ?)', (title, publisher))
        new_book_id = cursor.lastrowid
        cursor.execute('INSERT INTO BOOK_AUTHORS (Book_Id, Author_Name) VALUES (?, ?)', (new_book_id, author))
        copies_seed = [(new_book_id, bid, 5) for bid in range(1, 6)]
        cursor.executemany('INSERT OR REPLACE INTO BOOK_COPIES (Book_Id, Branch_Id, No_Of_Copies) VALUES (?, ?, ?)', copies_seed)
        db.commit()
        messagebox.showinfo("Success", f"Book '{title}' added (ID: {new_book_id}) with 5 copies at each branch.")
    except sqlite3.Error as e:
        messagebox.showerror("DB Error", str(e))
    hide_all()

def submit_list_copies():
    b_id = copies_book_id.get().strip()
    if not b_id:
        messagebox.showerror("Error", "Book ID required")
        return
    cursor.execute('SELECT Book_Id, Branch_Id, No_Of_Copies FROM BOOK_COPIES WHERE Book_Id = ?', (b_id,))
    rows = cursor.fetchall()
    if rows:
        show_results("Book Copies", ["Book_Id", "Branch_Id", "No_Of_Copies"], rows)
    else:
        messagebox.showinfo("No Data", "No copy records found for this Book ID.")
    hide_all()

def submit_list_borrower():
    c_id = list_borrower_id.get().strip()
    if not c_id:
        messagebox.showerror("Error", "Borrower ID required")
        return
    cursor.execute('SELECT Card_No, Name, Address, Phone FROM BORROWER WHERE Card_No = ?', (c_id,))
    rows = cursor.fetchall()
    if rows:
        show_results("Borrower Info", ["Card_No", "Name", "Address", "Phone"], rows)
    else:
        messagebox.showinfo("No Data", "No borrower found with that ID.")
    hide_all()

# ---------- Requirement 4: Copies Loaned Out by Book Title ----------
def submit_copies_loaned():
    title = loaned_title_entry.get().strip()
    if not title:
        messagebox.showerror("Error", "Please enter a book title")
        return
    query = '''
        SELECT LB.Branch_Name, COUNT(*) AS Copies_Loaned
        FROM BOOK_LOANS BL
        JOIN BOOK B ON BL.Book_Id = B.Book_Id
        JOIN LIBRARY_BRANCH LB ON BL.Branch_Id = LB.Branch_Id
        WHERE B.Title = ? AND BL.Returned_Date IS NULL
        GROUP BY LB.Branch_Name
        ORDER BY LB.Branch_Name
    '''
    cursor.execute(query, (title,))
    rows = cursor.fetchall()
    if rows:
        show_results(f"Copies Loaned Out for '{title}'", ["Branch Name", "Copies Loaned (Not Returned)"], rows)
    else:
        messagebox.showinfo("No active loans", f"No active (not returned) loans found for '{title}'.")
    hide_all()

# ---------- Requirement 6a: Borrower Late Fee Balance ----------
def submit_borrower_balance():
    borrower_id_val = balance_borrower_id_entry.get().strip()
    name_part = balance_name_entry.get().strip()
    query = '''
        SELECT 
            Card_No, 
            Borrower_Name, 
            COALESCE(SUM(LateFeeBalance), 0) AS TotalLateFeeBalance
        FROM vBookLoanInfo
        WHERE 1=1
    '''
    params = []
    if borrower_id_val:
        query += " AND Card_No = ?"
        params.append(borrower_id_val)
    if name_part:
        query += " AND Borrower_Name LIKE ?"
        params.append(f"%{name_part}%")
    query += " GROUP BY Card_No, Borrower_Name"
    if not borrower_id_val and not name_part:
        query += " ORDER BY TotalLateFeeBalance DESC"
    cursor.execute(query, params)
    rows = cursor.fetchall()
    if rows:
        formatted_rows = []
        for row in rows:
            card, name, bal = row
            formatted_rows.append((card, name, f"${bal:.2f}" if bal is not None else "$0.00"))
        show_results("Borrower Late Fee Balance", ["Card_No", "Name", "Total Balance"], formatted_rows)
    else:
        messagebox.showinfo("No data", "No borrowers found matching criteria.")
    hide_all()

# ---------- Requirement 6b: Book Info with Late Fee (by Borrower + optional book filters) ----------
def submit_book_info_latefee():
    borrower_id_val = book_info_borrower_id_entry.get().strip()
    if not borrower_id_val:
        messagebox.showerror("Error", "Borrower ID is required for this search")
        return
    book_id_val = book_info_book_id_entry.get().strip()
    title_part = book_info_title_entry.get().strip()
    query = '''
        SELECT 
            Book_Title,
            Book_Id,
            Branch_Id,
            Date_Out,
            Due_Date,
            Returned_Date,
            Days_Late,
            CASE 
                WHEN LateFeeBalance IS NULL OR LateFeeBalance = 0 THEN 'Non-Applicable'
                ELSE '$' || printf("%.2f", LateFeeBalance)
            END AS LateFeeDisplay
        FROM vBookLoanInfo
        WHERE Card_No = ?
    '''
    params = [borrower_id_val]
    if book_id_val:
        query += " AND Book_Id = ?"
        params.append(book_id_val)
    if title_part:
        query += " AND Book_Title LIKE ?"
        params.append(f"%{title_part}%")
    query += " ORDER BY LateFeeBalance DESC"
    cursor.execute(query, params)
    rows = cursor.fetchall()
    if rows:
        columns = ["Book Title", "Book ID", "Branch ID", "Date Out", "Due Date", "Returned Date", "Days Late", "Late Fee"]
        show_results(f"Book Loan Info for Borrower {borrower_id_val}", columns, rows)
    else:
        messagebox.showinfo("No data", "No book loans found for the given borrower and criteria.")
    hide_all()

